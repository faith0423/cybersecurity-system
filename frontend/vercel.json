{
  "version": 2,
  "builds": [
    {
      "src": "dist/cyber-incident-frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://cybersecurity-system-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/cyber-incident-frontend/$1"
    }
  ]
}